# ============================================================
# Toserba Qonita — Frontend Environment Variables
# ============================================================
# Copy file ini jadi .env (jangan diubah .env.example agar tetap jadi template)
#   cp .env.example .env
# Lalu isi nilai yang sesuai. JANGAN COMMIT FILE .env KE GIT!
# ============================================================

# Cloudflare Worker API URL
# Contoh: https://toko-wa-api.your-account.workers.dev
VITE_SPREADSHEET_API_URL=https://toko-wa-api.your-account.workers.dev

# ImgBB API Key untuk upload gambar produk & QRIS
# Cara dapat: https://api.imgbb.com → daftar → generate key
VITE_IMGBB_API_KEY=your-imgbb-api-key

# Akun admin awal (akan dibuat di database kalau belum ada)
# Setelah login pertama, ganti password lewat panel admin
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=GANTI-DENGAN-PASSWORD-KUAT

# Nomor WhatsApp tujuan checkout
# Format: kode negara 62, tanpa "+" atau "0" depan. Contoh: 6281234567890
VITE_WA_NUMBER=628xxxxxxxxxx
